# ── Trading mode ──────────────────────────────────────────
# Opciones: PAPER | LIVE
TRADING_MODE=PAPER

# ── Polymarket credentials (solo para modo LIVE) ──────────
POLY_PRIVATE_KEY=tu_private_key_aqui
POLY_API_KEY=tu_api_key_aqui
POLY_API_SECRET=tu_api_secret_aqui
POLY_API_PASSPHRASE=tu_passphrase_aqui
POLY_FUNDER_ADDRESS=tu_wallet_address_aqui

# ── Estrategia late value ─────────────────────────────────
ORDER_SIZE_USDC=1.0
MIN_EDGE=0.12
MAX_DAILY_LOSS_USDC=5.0
MAX_POSITION_USDC=10.0

# ── Timing ────────────────────────────────────────────────
ENTRY_WINDOW_S=90
MIN_TIME_S=10
LOOP_INTERVAL_MS=500

# ── Modelo ────────────────────────────────────────────────
VOL_DEFAULT=0.8
VOL_LOOKBACK_SECONDS=300

# ── Display ───────────────────────────────────────────────
STARTING_CAPITAL_USDC=100.0

# ── Bet sizing automático ─────────────────────────────────
AUTO_BET_SIZING=true
BET_FRACTION=0.02
BET_SIZE_MIN=0.5
BET_SIZE_MAX=5.0
DEAD_ZONE_PCT=0.03
MAX_ENTRY_PRICE=0.88
VOL_MULTIPLIER=1.0
CALIBRATION_ALPHA=0.1
TAKE_PROFIT_PRICE=0.88
